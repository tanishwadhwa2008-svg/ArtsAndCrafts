# ============================================================
# Arts & Handicrafts — Environment configuration (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# --- Runtime ---
NODE_ENV=development

# --- API (apps/api) ---
API_PORT=4000
API_HOST=localhost
# Comma-separated list of allowed browser origins for CORS
CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL) ---
POSTGRES_USER=arts
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=arts_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://arts:change_me_in_local_env@localhost:5432/arts_dev?schema=public

# --- Auth (self-managed JWT) ---
# Generate strong random secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Object storage (MinIO / S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_in_local_env
S3_BUCKET=arts-media
S3_FORCE_PATH_STYLE=true

# --- Frontend (apps/seller-web, Vite) ---
VITE_API_BASE_URL=http://localhost:4000/api/v1
