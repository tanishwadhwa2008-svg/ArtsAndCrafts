# ---------------------------------------------------------------------------
# Storefront (apps/storefront) environment
# Copy to `.env.local` and adjust. All values have local-dev defaults, so the
# app runs without this file; production must set real values.
# ---------------------------------------------------------------------------

# Public URL of the storefront itself. Used for metadata base, canonical URLs,
# and Open Graph tags. Exposed to the browser.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public base URL for media / object storage (MinIO in dev; S3 or a CDN in
# production). Its host is automatically added to next/image `remotePatterns`.
# Exposed to the browser.
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9000

# Server-side base URL for the public storefront API (used by React Server
# Components for data fetching). Server-only — never referenced from client code.
API_BASE_URL=http://localhost:4000/api/v1
